        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Intern notat for aa skille profilene fra hverandre senere. Vises ikke i iOS-utskriftsdialogen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
