    "Auswahl wird danach auf SecurePrint zurückgesetzt, damit du nicht versehentlich dauerhaft an ein Delegate druckst.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Afterwards the selection resets to SecurePrint so you don’t accidentally keep printing to a delegate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después, la selección vuelve a SecurePrint para que no sigas imprimiendo accidentalmente hacia un delegado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La sélection revient ensuite à SecurePrint pour éviter d’imprimer accidentellement vers un délégué de façon permanente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Successivamente la selezione torna a SecurePrint così non stampi accidentalmente in modo permanente verso un delegato."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Valget tilbakestilles etterpå til SecurePrint, slik at du ikke ved et uhell fortsetter å skrive ut til en delegat."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Daarna wordt de selectie teruggezet op SecurePrint, zodat je niet per ongeluk permanent naar een delegate print."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Valet återställs efteråt till SecurePrint så att du inte av misstag fortsätter skriva ut till en delegat."
          }
        }
      }
    },
    "auto_reset_caption": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auswahl wird danach auf SecurePrint zurückgesetzt, damit du nicht versehentlich dauerhaft an ein Delegate druckst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Selection will reset to SecurePrint afterwards so you don't accidentally print to a delegate permanently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La selección se restablecerá a SecurePrint para evitar impresión accidental."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La sélection sera réinitialisée sur SecurePrint pour éviter une impression accidentelle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La selezione verrà ripristinata su SecurePrint per evitare stampe accidentali."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Valget tilbakestilles til SecurePrint for å unngå utilsiktet utskrift."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De selectie wordt teruggezet naar SecurePrint om onbedoeld afdrukken te voorkomen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Valet återställs till SecurePrint för att undvika oavsiktlig utskrift."
          }
        }
      }
    },
