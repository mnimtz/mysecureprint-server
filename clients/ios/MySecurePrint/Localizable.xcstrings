    "Den QR-Code für die schnelle Einrichtung findest du im Self-Service-Bereich des Management-Portals unter „Mobile App“.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The QR code for quick setup is available in the self-service area of the Management Portal under “Mobile App”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El código QR para la configuración rápida está disponible en el área de autoservicio del portal de gestión en «Aplicación móvil»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code QR pour la configuration rapide est disponible dans la zone libre-service du portail de gestion sous « Application mobile »."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il codice QR per la configurazione rapida è disponibile nell’area self-service del portale di gestione sotto «App mobile»."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-koden for hurtig oppsett finner du i selvbetjeningsområdet i administrasjonsportalen under «Mobilapp»."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De QR-code voor snelle installatie vind je in het selfservicegedeelte van het Managementportaal onder „Mobiele app”."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-koden för snabbinställning hittar du i självbetjäningsområdet i hanteringsportalen under ”Mobilapp”."
          }
        }
      }
    },
