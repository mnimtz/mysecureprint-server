    "Zeigt Delegate-Ziele in der Ziele-Liste und erlaubt das Senden an andere Printix-Benutzer. Standardmäßig aus.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows delegate targets in the targets list and allows sending to other Printix users. Off by default."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra destinos de delegación en la lista y permite enviar a otros usuarios de Printix. Desactivado por defecto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche les destinations de délégation dans la liste et permet l'envoi à d'autres utilisateurs Printix. Désactivé par défaut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra le destinazioni di delega nell'elenco e consente l'invio ad altri utenti Printix. Disattivato per default."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Viser delegat-mål i mål-listen og lar deg sende til andre Printix-brukere. Av som standard."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toont delegatie-doelen in de lijst en staat verzenden naar andere Printix-gebruikers toe. Standaard uit."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Visar delegat-mål i mål-listan och tillåter sändning till andra Printix-användare. Av som standard."
          }
        }
      }
    },
