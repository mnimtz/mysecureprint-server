    "Hier landen deine Aufträge nach dem Senden — inkl. Status (an Printix gesendet, gedruckt, Fehler).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your jobs appear here after sending — including status (sent to Printix, printed, error)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus trabajos aparecen aquí después de enviar — incluyendo el estado (enviado a Printix, impreso, error)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos travaux s’affichent ici après envoi — avec l’état (envoyé à Printix, imprimé, erreur)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi lavori appaiono qui dopo l’invio — incluso lo stato (inviato a Printix, stampato, errore)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jobbene dine vises her etter sending — inkl. status (sendt til Printix, skrevet ut, feil)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw taken verschijnen hier na het verzenden — incl. status (verzonden naar Printix, afgedrukt, fout)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina jobb visas här efter utskick — inkl. status (skickat till Printix, utskrivet, fel)."
          }
        }
      }
    },
    "Hier landen deine Aufträge nach dem Senden — inkl. Status (bereit zur Abholung, fehlgeschlagen).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your jobs will appear here after sending — with status (ready for pickup, failed)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí verás tus trabajos después de enviarlos — con estado (listo para recoger, fallido)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes travaux apparaissent ici après envoi — avec statut (prêt à retirer, échec)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qui trovi i tuoi lavori dopo l'invio — con stato (pronto, fallito)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Her havner utskriftsjobbene dine etter sending — inkl. status (klar for henting, mislyktes)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hier verschijnen je opdrachten na verzending — incl. status (klaar om op te halen, mislukt)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Här hamnar dina jobb efter sändning — inkl. status (klar för hämtning, misslyckades)."
          }
        }
      }
    },
    "Hier landen deine Aufträge nach dem Senden — inkl. Status (gesendet, fehlgeschlagen).": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your jobs will appear here after sending — with status (sent, failed)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
