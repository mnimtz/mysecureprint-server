    "airprint_empty_hint": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe unten auf „Neuen Drucker hinzufügen“ um ein Profil zu erstellen. Du kannst danach aus jeder iOS-, iPadOS- oder macOS-App direkt drucken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap 'Add new printer' below to create a profile. Afterwards you can print from any iOS, iPadOS or macOS app directly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca 'Anadir impresora nueva' abajo para crear un perfil. Despues podras imprimir directamente desde cualquier app de iOS, iPadOS o macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur 'Ajouter une imprimante' ci-dessous pour creer un profil. Tu pourras ensuite imprimer directement depuis toute app iOS, iPadOS ou macOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca 'Aggiungi nuova stampante' qui sotto per creare un profilo. Poi potrai stampare direttamente da qualsiasi app iOS, iPadOS o macOS."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk 'Legg til ny skriver' nedenfor for aa opprette en profil. Deretter kan du skrive ut direkte fra enhver iOS-, iPadOS- eller macOS-app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik hieronder op 'Nieuwe printer toevoegen' om een profiel te maken. Daarna kun je vanuit elke iOS-, iPadOS- of macOS-app rechtstreeks printen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em 'Adicionar nova impressora' abaixo para criar um perfil. Depois voce podera imprimir diretamente de qualquer app iOS, iPadOS ou macOS."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck pa 'Lagg till ny skrivare' nedan for att skapa en profil. Sedan kan du skriva ut direkt fran valfri iOS-, iPadOS- eller macOS-app."
