        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vind de QR-code voor snelle instelling in het selfservicegedeelte van de beheerportal."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hitta QR-koden för snabbinstallation i självbetjäningsområdet i hanteringsportalen."
          }
        }
      }
    },
    "Der Admin hat Delegation-Druck für diesen Server deaktiviert. Frage in der Server-Verwaltung nach, wenn du diese Funktion brauchst.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The admin has disabled delegation printing for this server. Contact your server administrator if you need this feature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El administrador ha desactivado la impresión delegada para este servidor. Contacta con el administrador si necesitas esta función."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'administrateur a désactivé l'impression déléguée pour ce serveur. Contacte l'administrateur si tu as besoin de cette fonctionnalité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'amministratore ha disattivato la stampa delegata per questo server. Contatta l'amministratore se ti serve questa funzione."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrator har deaktivert delegert utskrift for denne serveren. Ta kontakt med administrator hvis du trenger denne funksjonen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De beheerder heeft delegatie-printen voor deze server uitgeschakeld. Neem contact op met de beheerder als je deze functie nodig hebt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Administratören har inaktiverat delegerad utskrift för denna server. Kontakta administratören om du behöver denna funktion."
          }
        }
      }
    },
    "Der Admin hat erlaubt, dass du an eine beliebige Tenant-Queue drucken kannst — wähle zusätzlich aus.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The admin has allowed you to print to any tenant queue — choose one additionally."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El administrador te permite imprimir a cualquier cola del tenant — selecciona una adicional."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'administrateur t'autorise à imprimer sur n'importe quelle file du tenant — sélectionne-en une en plus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'amministratore ti consente di stampare su qualsiasi coda del tenant — selezionane una in aggiunta."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrator har gitt deg tilgang til å skrive ut til alle tenant-køer — velg en i tillegg."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De beheerder staat je toe naar elke tenant-wachtrij te printen — kies er nog een."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Administratören låter dig skriva ut till valfri tenant-kö — välj en till."
          }
        }
      }
    },
