          "stringUnit": {
            "state": "translated",
            "value": "Jetzt musst du das Profil noch auf diesem Gerät installieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now install the profile on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ahora instala el perfil en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il ne reste qu'a installer le profil sur cet appareil."
