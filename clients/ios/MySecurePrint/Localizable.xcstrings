    "Bilder werden graustufen-konvertiert. Für Dokumente gilt die Drucker-Einstellung.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Images are converted to grayscale. For documents, the printer setting applies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las imágenes se convierten a escala de grises. Para documentos se aplica la configuración de la impresora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
