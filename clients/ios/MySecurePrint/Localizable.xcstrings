    "Die Karte wird bei Printix und lokal entfernt. Druckfreigabe am Geraet funktioniert danach nicht mehr.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Karte wird bei Printix und lokal entfernt. Druckfreigabe am Gerät funktioniert danach nicht mehr."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The card will be removed from Printix and locally. Print release at the device will no longer work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tarjeta se eliminará de Printix y localmente. La liberación de impresión en el dispositivo dejará de funcionar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La carte sera supprimée de Printix et en local. La libération de l'impression sur l'appareil ne fonctionnera plus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La carta sarà rimossa da Printix e localmente. Il rilascio di stampa sul dispositivo non funzionerà più."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kortet fjernes fra Printix og lokalt. Utskriftsfrigjøring på enheten vil ikke lenger fungere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De kaart wordt uit Printix en lokaal verwijderd. Printrelease op het apparaat werkt daarna niet meer."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kortet tas bort från Printix och lokalt. Utskriftsfrisläppning vid enheten fungerar inte längre."
          }
        }
      }
    },
