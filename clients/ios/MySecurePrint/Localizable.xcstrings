        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota interna para distinguir tus perfiles mas tarde. No se muestra en el dialogo de impresion de iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
