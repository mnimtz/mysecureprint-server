    "Delegiert von": {},
    "Den QR-Code für die schnelle Einrichtung findest du im Self-Service-Bereich des Management-Portals unter „Mobile App“.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The QR code for quick setup is available in the self-service area of the Management Portal under “Mobile App”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El código QR para la configuración rápida está disponible en el área de autoservicio del portal de gestión en «Aplicación móvil»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code QR pour la configuration rapide est disponible dans la zone libre-service du portail de gestion sous « Application mobile »."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il codice QR per la configurazione rapida è disponibile nell’area self-service del portale di gestione sotto «App mobile»."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-koden for hurtig oppsett finner du i selvbetjeningsområdet i administrasjonsportalen under «Mobilapp»."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De QR-code voor snelle installatie vind je in het selfservicegedeelte van het Managementportaal onder „Mobiele app”."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-koden för snabbinställning hittar du i självbetjäningsområdet i hanteringsportalen under ”Mobilapp”."
          }
        }
      }
    },
    "Den QR-Code für die schnelle Einrichtung findest du im Self-Service-Bereich des Management-Portals.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find the QR code for quick setup in the self-service area of the management portal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encuentra el código QR para la configuración rápida en el área de autoservicio del portal de gestión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouvez le QR code pour la configuration rapide dans la zone libre-service du portail de gestion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trova il codice QR per la configurazione rapida nell’area self-service del portale di gestione."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Finn QR-koden for rask oppsett i selvbetjeningsområdet på administrasjonsportalen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vind de QR-code voor snelle instelling in het selfservicegedeelte van de beheerportal."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hitta QR-koden för snabbinstallation i självbetjäningsområdet i hanteringsportalen."
          }
        }
      }
    },
    "Der Admin hat Delegation-Druck für diesen Server deaktiviert. Frage in der Server-Verwaltung nach, wenn du diese Funktion brauchst.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The admin has disabled delegation printing for this server. Contact your server administrator if you need this feature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El administrador ha desactivado la impresión delegada para este servidor. Contacta con el administrador si necesitas esta función."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'administrateur a désactivé l'impression déléguée pour ce serveur. Contacte l'administrateur si tu as besoin de cette fonctionnalité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'amministratore ha disattivato la stampa delegata per questo server. Contatta l'amministratore se ti serve questa funzione."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrator har deaktivert delegert utskrift for denne serveren. Ta kontakt med administrator hvis du trenger denne funksjonen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De beheerder heeft delegatie-printen voor deze server uitgeschakeld. Neem contact op met de beheerder als je deze functie nodig hebt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Administratören har inaktiverat delegerad utskrift för denna server. Kontakta administratören om du behöver denna funktion."
          }
        }
      }
    },
    "Der Admin hat erlaubt, dass du an eine beliebige Tenant-Queue drucken kannst — wähle zusätzlich aus.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The admin has allowed you to print to any tenant queue — choose one additionally."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El administrador te permite imprimir a cualquier cola del tenant — selecciona una adicional."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'administrateur t'autorise à imprimer sur n'importe quelle file du tenant — sélectionne-en une en plus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'amministratore ti consente di stampare su qualsiasi coda del tenant — selezionane una in aggiunta."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrator har gitt deg tilgang til å skrive ut til alle tenant-køer — velg en i tillegg."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De beheerder staat je toe naar elke tenant-wachtrij te printen — kies er nog een."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Administratören låter dig skriva ut till valfri tenant-kö — välj en till."
          }
        }
      }
    },
