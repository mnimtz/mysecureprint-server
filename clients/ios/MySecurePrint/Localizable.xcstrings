    "airprint_wizard_display_name_footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Interne Notiz um deine Profile später auseinanderhalten zu können. Wird nicht im iOS-Print-Dialog gezeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Internal note to tell your profiles apart later. Not shown in the iOS print dialog."
