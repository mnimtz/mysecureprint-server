        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk 'Aapne profil' – iOS viser forhaandsvisningen"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op 'Profiel openen' -- iOS toont het voorbeeld"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em 'Abrir perfil': o iOS mostrara a pre-visualizacao"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck 'Oppna profil' -- iOS visar forhandsvisningen"
          }
        }
      }
    },
    "airprint_install_step2": {
      "extractionState": "manual",
      "localizations": {
