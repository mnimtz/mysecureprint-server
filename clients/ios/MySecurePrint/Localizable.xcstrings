        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle die Queue in die deine Druck-Aufträge geschickt werden sollen. Das Profil funktioniert auf iPhone, iPad und Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick the queue you want your print jobs sent to. The profile works on iPhone, iPad and Mac."
          }
