    "airprint_intro": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Native Drucker-Profile für iPhone, iPad und Mac. Nach Installation kannst du aus jeder App direkt in deine SecurePrint-Queue drucken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Native printer profiles for iPhone, iPad and Mac. After installing you can print from any app directly to your SecurePrint queue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Perfiles de impresora nativos para iPhone, iPad y Mac. Después de instalar puedes imprimir desde cualquier app directamente a tu cola SecurePrint."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profils d'imprimante natifs pour iPhone, iPad et Mac. Après installation, tu peux imprimer depuis n'importe quelle app directement dans ta file SecurePrint."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Profili di stampante nativi per iPhone, iPad e Mac. Dopo l'installazione puoi stampare da qualsiasi app direttamente nella tua coda SecurePrint."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Native skriverprofiler for iPhone, iPad og Mac. Etter installasjon kan du skrive ut fra hvilken som helst app direkte til SecurePrint-koen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Native printerprofielen voor iPhone, iPad en Mac. Na installatie kun je vanuit elke app rechtstreeks in je SecurePrint-wachtrij printen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Perfis de impressora nativos para iPhone, iPad e Mac. Apos a instalacao voce pode imprimir de qualquer app diretamente na sua fila SecurePrint."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Native skrivarprofiler for iPhone, iPad och Mac. Efter installation kan du skriva ut fran valfri app direkt till din SecurePrint-ko."
