    "delegation_picker_sub": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle weitere Printix-Benutzer aus. Der Druckjob wird zusätzlich an deren Secure-Print-Queue gesendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select additional Printix users. The print job will also be sent to their Secure Print queue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona otros usuarios Printix. El trabajo también se enviará a su cola segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez d'autres utilisateurs Printix. Le travail sera aussi envoyé dans leur file sécurisée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona altri utenti Printix. Il lavoro verrà inviato anche alla loro coda sicura."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg flere Printix-brukere. Utskriftsjobben sendes også til deres sikre kø."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecteer extra Printix-gebruikers. De afdruktaak wordt ook naar hun beveiligde wachtrij gestuurd."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj fler Printix-användare. Utskriftsjobbet skickas även till deras säkra kö."
          }
        }
      }
    },
