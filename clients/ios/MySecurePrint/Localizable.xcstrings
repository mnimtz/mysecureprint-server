            "value": "Select additional Printix users. The print job will also be sent to their secure print queue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona más usuarios de Printix. El trabajo se enviará también a su cola Secure-Print."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionne d'autres utilisateurs Printix. Le travail sera aussi envoyé à leur file Secure-Print."
