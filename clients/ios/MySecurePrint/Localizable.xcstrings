            "value": "Qui trovi i tuoi lavori dopo l'invio — con stato (inviato, fallito)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Her havner utskriftsjobbene dine etter sending — inkl. status (sendt, mislyktes)."
          }
        },
        "nl": {
          "stringUnit": {
