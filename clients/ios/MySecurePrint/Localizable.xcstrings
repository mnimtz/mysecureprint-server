    "airprint_install_step1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf 'Profil öffnen' tippen — iOS zeigt dann die Vorschau"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap 'Open profile' -- iOS will show the preview"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca 'Abrir perfil': iOS mostrara la vista previa"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur 'Ouvrir le profil' -- iOS affichera l'apercu"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca 'Apri profilo': iOS mostrera l'anteprima"
          }
