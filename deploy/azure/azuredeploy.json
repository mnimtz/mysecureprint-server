{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "mysecureprint-server — Azure App Service for the MySecurePrint iOS app. Creates Plan + Linux Web App + Azure Files share at /data."
  },
  "parameters": {
    "appName": { "type": "string", "metadata": { "description": "Unique app name. Reachable at https://<appName>.azurewebsites.net" } },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "sku": {
      "type": "string", "defaultValue": "B1",
      "allowedValues": [ "F1", "B1", "B2", "B3", "S1", "P1V3" ],
      "metadata": { "description": "B1 recommended (~10 EUR/month). F1 is free with limits (1 GB RAM, sleeps when idle)." }
    },
    "containerImage": { "type": "string", "defaultValue": "ghcr.io/mnimtz/mysecureprint-server:latest" },
    "publicUrl": { "type": "string", "defaultValue": "", "metadata": { "description": "Optional. Defaults to https://<appName>.azurewebsites.net." } },
    "tz": { "type": "string", "defaultValue": "Europe/Berlin" },
    "logLevel": { "type": "string", "defaultValue": "info", "allowedValues": [ "debug", "info", "warning", "error" ] }
  },
  "variables": {
    "planName": "[concat(parameters('appName'), '-plan')]",
    "storageAccountName": "[concat('mysprt', uniqueString(resourceGroup().id))]",
    "fileShareName": "printix-data",
    "effectivePublicUrl": "[if(empty(parameters('publicUrl')), concat('https://', parameters('appName'), '.azurewebsites.net'), parameters('publicUrl'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": { "minimumTlsVersion": "TLS1_2", "allowBlobPublicAccess": false }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('storageAccountName'), '/default/', variables('fileShareName'))]",
      "dependsOn": [ "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]" ],
      "properties": { "shareQuota": 5 }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "[parameters('sku')]" },
      "kind": "linux",
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux,container",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', variables('storageAccountName'), 'default', variables('fileShareName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', parameters('containerImage'))]",
          "alwaysOn": "[if(equals(parameters('sku'), 'F1'), false(), true())]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            { "name": "WEBSITES_PORT", "value": "8080" },
            { "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE", "value": "false" },
            { "name": "DOCKER_REGISTRY_SERVER_URL", "value": "https://ghcr.io" },
            { "name": "MCP_PUBLIC_URL", "value": "[variables('effectivePublicUrl')]" },
            { "name": "MCP_LOG_LEVEL", "value": "[parameters('logLevel')]" },
            { "name": "WEB_PORT", "value": "8080" },
            { "name": "TZ", "value": "[parameters('tz')]" }
          ],
          "azureStorageAccounts": {
            "data": {
              "type": "AzureFiles",
              "accountName": "[variables('storageAccountName')]",
              "shareName": "[variables('fileShareName')]",
              "mountPath": "/data",
              "accessKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "appUrl": { "type": "string", "value": "[concat('https://', parameters('appName'), '.azurewebsites.net')]" },
    "storageAccount": { "type": "string", "value": "[variables('storageAccountName')]" },
    "nextSteps": { "type": "string", "value": "Open the App URL, register the first admin account, configure Printix credentials under /admin/settings, and fill in /admin/settings#legal so /privacy and /imprint are App-Review-ready." }
  }
}
